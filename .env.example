# Copy to .env and fill in. .env is gitignored.

# Your Stash GraphQL endpoint (include /graphql).
STASH_URL=https://stash.example.ts.net/graphql

# Stash API key: Settings > Security > API Key. Leave blank if auth is disabled.
STASH_API_KEY=

# Egress is handled by a system VPN (e.g. ProtonVPN); the scraper uses no proxy.

# Tag id stamped on every scene that enrichment writes to (a marker tag). Unset
# to disable. Find the id in Stash: Tags > the tag > the number in its URL.
# CLIPSTORE_ENRICH_TAG=42

# Parallel workers for "Scrape all" and enrich --apply. Defaults to your CPU
# thread count. All scraping is HTTP (no browser), so this is cheap; set 1 for
# fully sequential.
# CLIPSTORE_SCRAPE_CONCURRENCY=8
